# .frank.toml — persistent config for frank CLI
# Resolution order: CLI flags > env vars > .frank.toml > defaults

hugo_dir = "/path/to/hugo-blog"
state_db = ".frank-state.db"
llm_provider = "anthropic"
llm_model = ""
# day or week
period = "week"
# ordered list of post-processing skills to run (from skills/ directory)
# skills = ["humanizer"]
# upstream URLs for skill definitions (used by `frank update skill <name>`)
# skill_url_humanizer = "https://raw.githubusercontent.com/blader/humanizer/main/SKILL.md"
